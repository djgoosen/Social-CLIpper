{
  "name": "Social CLIpper",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "hostRequirements": {
    "memory": "16gb"
  },
  "runArgs": [
    "--memory=48g",
    "--memory-swap=48g",
    "--shm-size=2g"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.testing.pytestArgs": ["tests"]
      }
    }
  },
  "postCreateCommand": "python3 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt",
  // "postCreateCommand": "python3 -m pip install -U pip setuptools wheel && python3 -m pip install -e \".[whisper,dev]\"",
  "remoteUser": "vscode"
}
